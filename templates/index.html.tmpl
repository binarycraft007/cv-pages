<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Name}}</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <main>
        <section>
            <h2>NAME</h2>
            <p>{{.Name}}</p>
        </section>
        <section>
            <h2>SYNOPSIS</h2>
            <p>
                <a href="mailto:{{.Synopsis.Email}}">[email]</a>
                <a href="{{.Synopsis.Linkedin}}" target="_blank">[linkedin]</a>
                <a href="{{.Synopsis.Github}}" target="_blank">[github]</a>
            </p>
        </section>
        <section>
            <h2>DESCRIPTION</h2>
            <p>{{.Description}}</p>
        </section>
        <section>
            <h2>SKILLS</h2>
            <ul>
                {{range .Skills}}
                <li>{{.}}</li>
                {{end}}
            </ul>
        </section>
        <section>
            <h2>PROJECTS</h2>
            {{range .Projects}}
            <div class="project">
                <h3>{{.Title}}</h3>
                <p>{{.Description}}</p>
                <a href="{{.URL}}" target="_blank">View Project</a>
            </div>
            {{end}}
        </section>
        <section>
            <h2>EXPERIENCE</h2>
            {{range .Experience}}
            <div class="experience">
                <h3>{{.Company}} - {{.Title}}</h3>
                <p class="dates">{{.Dates}}</p>
                <p>{{.Description}}</p>
            </div>
            {{end}}
        </section>
        <section>
            <h2>EDUCATION</h2>
            {{range .Education}}
            <div class="education">
                <h3>{{.Degree}}</h3>
                <p>{{.Institution}} ({{.Dates}})</p>
            </div>
            {{end}}
        </section>
        <section>
            <h2>SEE ALSO</h2>
            <p>
                {{range .SeeAlso}}
                <a href="{{.URL}}" target="_blank">{{.Name}}</a>
                {{end}}
            </p>
        </section>
    </main>
</body>
</html>
